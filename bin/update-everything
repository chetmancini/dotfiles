#!/usr/bin/env bash
# shellcheck shell=bash
set -euo pipefail

# update-everything: Update all software and pull latest code
#
# Configuration file: ~/.config/good-morning/config
# Can be run standalone or called from good-morning
#
# Dependencies:
#   Required:  brew (Homebrew), git
#   Optional (tasks are skipped if the tool is absent or not running):
#     docker          Docker cleanup
#     nvim            Neovim plugin updates
#     softwareupdate  macOS system updates (built-in, macOS only)

# Get the directory where this script lives
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Source shared helpers
source "$SCRIPT_DIR/lib/helpers.sh"

CONFIG_DIR="$HOME/.config/good-morning"
CONFIG_FILE="$CONFIG_DIR/config"

# Default configuration
DEFAULT_REPOS_DIRS=("$HOME/code" "$HOME/norm")
DEFAULT_RUN_BREW_UPDATE=true
DEFAULT_RUN_BREW_UPGRADE=true
DEFAULT_RUN_BREW_CLEANUP=true
DEFAULT_RUN_NPM_GLOBAL_UPDATE=true
DEFAULT_PULL_REPOS=true
DEFAULT_DOCKER_PRUNE=true
DEFAULT_CHECK_MACOS_UPDATES=true
DEFAULT_UPDATE_NVIM_PLUGINS=true
# Controls whether repo git fetches run in parallel.
DEFAULT_PARALLEL=true

# Load configuration or use defaults
load_config() {
    REPOS_DIRS=("${DEFAULT_REPOS_DIRS[@]}")
    RUN_BREW_UPDATE="$DEFAULT_RUN_BREW_UPDATE"
    RUN_BREW_UPGRADE="$DEFAULT_RUN_BREW_UPGRADE"
    RUN_BREW_CLEANUP="$DEFAULT_RUN_BREW_CLEANUP"
    RUN_NPM_GLOBAL_UPDATE="$DEFAULT_RUN_NPM_GLOBAL_UPDATE"
    PULL_REPOS="$DEFAULT_PULL_REPOS"
    DOCKER_PRUNE="$DEFAULT_DOCKER_PRUNE"
    CHECK_MACOS_UPDATES="$DEFAULT_CHECK_MACOS_UPDATES"
    UPDATE_NVIM_PLUGINS="$DEFAULT_UPDATE_NVIM_PLUGINS"
    PARALLEL="$DEFAULT_PARALLEL"

    if [ -f "$CONFIG_FILE" ]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    fi
}

# Temporary directory for parallel output
TEMP_DIR=""
setup_temp_dir() {
    TEMP_DIR=$(mktemp -d)
    trap 'rm -rf "$TEMP_DIR"' EXIT INT TERM
}

# Emit a concise Homebrew upgrade report from outdated snapshots.
# Arguments: label before_verbose_file after_names_file
emit_brew_upgrade_report() {
    local label="$1"
    local before_file="$2"
    local after_file="$3"
    local updated_count=0
    local line name target_version
    local -a updated_entries=()

    [ -f "$before_file" ] || return 0

    while IFS= read -r line; do
        [ -n "$line" ] || continue

        # brew outdated --verbose format is "<name> (...) <target>" (or "!= <target>" for some casks)
        name="${line%% *}"
        target_version="${line##* }"

        if [ -f "$after_file" ] && grep -qx "$name" "$after_file"; then
            continue
        fi

        updated_entries+=("$name $target_version")
        ((updated_count++))
    done <"$before_file"

    if [ "$updated_count" -eq 0 ]; then
        echo "info:$label updated: none"
        return 0
    fi

    echo "info:$label updated: $updated_count"
    for entry in "${updated_entries[@]}"; do
        echo "info:  - $entry"
    done
}

timestamp() {
    date "+%Y-%m-%d %H:%M:%S"
}

# Run a command and append all output to a log file with timestamps.
# Arguments: log_file label cmd [args...]
run_logged_command() {
    local log_file="$1"
    local label="$2"
    shift 2
    local status=0

    {
        echo "[$(timestamp)] START: $label"
        if "$@"; then
            status=0
        else
            status=$?
        fi
        echo "[$(timestamp)] END: $label (exit $status)"
    } >>"$log_file" 2>&1

    return "$status"
}

# Homebrew tasks (must run sequentially: update -> upgrade -> cleanup)
run_brew_tasks() {
    local output_file="$TEMP_DIR/brew.out"
    local log_file="$TEMP_DIR/brew.log"

    {
        : >"$log_file"

        if [ "$RUN_BREW_UPDATE" = true ]; then
            echo "section:Updating Homebrew..."
            echo "info:Homebrew log: $log_file"
            echo "info:[$(timestamp)] Running brew update"
            if run_logged_command "$log_file" "brew update" brew update; then
                echo "success:Homebrew updated"
            else
                echo "error:Failed to update Homebrew"
                echo "info:Check log: $log_file"
            fi
        fi

        if [ "$RUN_BREW_UPGRADE" = true ]; then
            echo "section:Upgrading packages..."
            echo "info:Homebrew log: $log_file"
            echo "info:[$(timestamp)] Capturing outdated package snapshots"
            local formula_before="$TEMP_DIR/brew_formula_before.out"
            local formula_after="$TEMP_DIR/brew_formula_after.out"
            local cask_before="$TEMP_DIR/brew_cask_before.out"
            local cask_after="$TEMP_DIR/brew_cask_after.out"

            brew outdated --formula --verbose >"$formula_before" 2>>"$log_file" || true
            brew outdated --cask --verbose >"$cask_before" 2>>"$log_file" || true

            echo "info:[$(timestamp)] Running brew upgrade"
            if run_logged_command "$log_file" "brew upgrade" brew upgrade; then
                brew outdated --formula >"$formula_after" 2>>"$log_file" || true
                brew outdated --cask >"$cask_after" 2>>"$log_file" || true
                echo "success:Packages upgraded"
                emit_brew_upgrade_report "Packages" "$formula_before" "$formula_after"
                emit_brew_upgrade_report "Apps" "$cask_before" "$cask_after"
            else
                echo "error:Failed to upgrade packages"
                echo "info:Check log: $log_file"
            fi
        fi

        if [ "$RUN_BREW_CLEANUP" = true ]; then
            echo "section:Cleaning up Homebrew..."
            echo "info:Homebrew log: $log_file"
            echo "info:[$(timestamp)] Running brew cleanup"
            if run_logged_command "$log_file" "brew cleanup" brew cleanup; then
                echo "success:Homebrew cleaned up"
            else
                echo "error:Failed to cleanup Homebrew"
                echo "info:Check log: $log_file"
            fi
        fi
    } >"$output_file"
}

run_npm_global_update() {
    local output_file="$TEMP_DIR/npm.out"
    local log_file="$TEMP_DIR/npm-global.log"

    {
        if [ "$RUN_NPM_GLOBAL_UPDATE" != true ]; then
            exit 0
        fi

        echo "section:Updating global npm packages..."

        if ! command -v npm &>/dev/null; then
            echo "info:npm is not installed, skipping"
            exit 0
        fi

        : >"$log_file"
        echo "info:npm global update log: $log_file"
        echo "info:[$(timestamp)] Running npm update -g"

        if run_logged_command "$log_file" "npm update -g" npm update -g; then
            echo "success:Global npm packages updated"
        else
            echo "error:Failed to update global npm packages"
            echo "info:Check log: $log_file"
        fi
    } >"$output_file"
}

# Print output from a task file
print_task_output() {
    local output_file="$1"
    [ -f "$output_file" ] || return 0

    while IFS=: read -r type message; do
        case "$type" in
            section)
                print_section "$message"
                echo ""
                ;;
            success) print_success "$message" ;;
            error) print_error "$message" ;;
            info) print_info "$message" ;;
        esac
    done <"$output_file"
}

# Check for macOS updates (just report, don't install)
check_macos_updates() {
    local output_file="$TEMP_DIR/macos.out"

    {
        if [ "$CHECK_MACOS_UPDATES" != true ]; then
            exit 0
        fi

        # Only run on macOS
        if [ "$(uname)" != "Darwin" ]; then
            exit 0
        fi

        echo "section:Checking for macOS updates..."

        # softwareupdate -l lists available updates
        updates=$(softwareupdate -l 2>&1)

        if echo "$updates" | grep -q "No new software available"; then
            echo "success:macOS is up to date"
        else
            # Count updates (lines starting with *)
            update_count=$(echo "$updates" | grep -c "^\*" || true)
            if [ "$update_count" -gt 0 ]; then
                echo "error:$update_count macOS update(s) available"
                echo "$updates" | grep "^\*" | while read -r line; do
                    echo "info:  $line"
                done
                echo "info:  Run 'softwareupdate -i -a' to install all updates"
            else
                echo "success:macOS is up to date"
            fi
        fi
    } >"$output_file"
}

# Docker cleanup
run_docker_prune() {
    local output_file="$TEMP_DIR/docker.out"

    {
        if [ "$DOCKER_PRUNE" != true ]; then
            exit 0
        fi

        # Check if Docker is installed and running
        if ! command -v docker &>/dev/null; then
            exit 0
        fi

        if ! docker info &>/dev/null; then
            echo "section:Docker cleanup..."
            echo "info:Docker is not running, skipping"
            exit 0
        fi

        echo "section:Cleaning up Docker..."

        # Get space before cleanup
        space_before=$(docker system df --format '{{.Reclaimable}}' 2>/dev/null | head -1)

        if docker system prune -f &>/dev/null; then
            echo "success:Docker cleaned up (was reclaimable: $space_before)"
        else
            echo "error:Failed to clean up Docker"
        fi
    } >"$output_file"
}

# Update Neovim plugins via Lazy
update_nvim_plugins() {
    local output_file="$TEMP_DIR/nvim.out"

    {
        if [ "$UPDATE_NVIM_PLUGINS" != true ]; then
            exit 0
        fi

        # Check if nvim is installed
        if ! command -v nvim &>/dev/null; then
            exit 0
        fi

        echo "section:Updating Neovim plugins..."

        if nvim --headless "+Lazy! sync" +qa 2>/dev/null; then
            echo "success:Neovim plugins updated"
        else
            echo "error:Failed to update Neovim plugins"
        fi
    } >"$output_file"
}

# Fetch a single repo (safe to run in parallel)
# Arguments: repo_path output_file failed_file
fetch_single_repo() {
    local repo="$1"
    local output_file="$2"
    local failed_file="$3"
    local repo_name
    repo_name=$(basename "$repo")

    (
        cd "$repo"

        if ! git fetch origin 2>/dev/null; then
            echo "error:$repo_name: failed to fetch" >>"$output_file"
            echo "$repo" >>"$failed_file"
            exit 0
        fi
    )
}

# Update a single repo after fetch (runs serially)
# Arguments: repo_path output_file
update_single_repo() {
    local repo="$1"
    local output_file="$2"
    local repo_name
    local branch
    local current_branch
    repo_name=$(basename "$repo")

    (
        cd "$repo"

        # Detect the primary branch (try main first, then master)
        if git show-ref --verify --quiet "refs/remotes/origin/main"; then
            branch="main"
        elif git show-ref --verify --quiet "refs/remotes/origin/master"; then
            branch="master"
        else
            echo "error:$repo_name: no main/master branch found" >>"$output_file"
            exit 0
        fi

        current_branch=$(git rev-parse --abbrev-ref HEAD)

        if [ "$current_branch" = "$branch" ]; then
            local stashed=false
            # If we're on the primary branch with local changes, stash before pulling.
            if [ -n "$(git status --porcelain 2>/dev/null)" ]; then
                if git stash push -m "update-everything auto-stash" 2>/dev/null; then
                    stashed=true
                else
                    echo "error:$repo_name: failed to stash changes, skipping pull" >>"$output_file"
                    exit 0
                fi
            fi

            if git pull --ff-only origin "$branch" 2>/dev/null; then
                if [ "$stashed" = true ]; then
                    if git stash pop 2>/dev/null; then
                        echo "success:$repo_name: pulled latest on $branch (stashed changes restored)" >>"$output_file"
                    else
                        echo "error:$repo_name: pulled latest on $branch but failed to restore stash (conflicts?)" >>"$output_file"
                    fi
                else
                    echo "success:$repo_name: pulled latest on $branch" >>"$output_file"
                fi
            else
                if [ "$stashed" = true ]; then
                    git stash pop 2>/dev/null || true
                fi
                echo "error:$repo_name: failed to pull (might need rebase)" >>"$output_file"
            fi
        else
            # On a different branch, refresh the local primary branch pointer from origin.
            if git show-ref --verify --quiet "refs/heads/$branch"; then
                if git merge-base --is-ancestor "$branch" "origin/$branch" 2>/dev/null; then
                    if git branch -f "$branch" "origin/$branch" 2>/dev/null; then
                        echo "success:$repo_name: updated $branch (currently on $current_branch)" >>"$output_file"
                    else
                        echo "error:$repo_name: failed to update local $branch from origin/$branch" >>"$output_file"
                    fi
                else
                    echo "info:$repo_name: local $branch has diverged from origin/$branch; not updating pointer" >>"$output_file"
                fi
            else
                if git branch "$branch" "origin/$branch" 2>/dev/null; then
                    echo "success:$repo_name: created local $branch from origin/$branch (currently on $current_branch)" >>"$output_file"
                else
                    echo "error:$repo_name: failed to create local $branch from origin/$branch" >>"$output_file"
                fi
            fi
        fi
    )
}

# Pull latest from main on all git repos in configured directories
pull_repos() {
    if [ "$PULL_REPOS" != true ]; then
        return
    fi

    local output_file="$TEMP_DIR/repos.out"
    local failed_file="$TEMP_DIR/repos_fetch_failed.list"
    : >"$failed_file"
    touch "$output_file"

    local -a repos=()
    local pids=()

    for repos_dir in "${REPOS_DIRS[@]}"; do
        if [ ! -d "$repos_dir" ]; then
            echo "info:Skipping $repos_dir (not found)" >>"$output_file"
            continue
        fi

        for repo in "$repos_dir"/*/; do
            if [ -d "$repo/.git" ]; then
                repos+=("$repo")
            fi
        done
    done

    if [ "${#repos[@]}" -eq 0 ]; then
        echo "info:No git repositories found" >>"$output_file"
        return
    fi

    echo "section:Fetching remotes..." >>"$output_file"
    if [ "$PARALLEL" = true ]; then
        echo "info:Running git fetch in parallel across repositories" >>"$output_file"
        for repo in "${repos[@]}"; do
            fetch_single_repo "$repo" "$output_file" "$failed_file" &
            pids+=($!)
        done

        for pid in "${pids[@]}"; do
            wait "$pid" 2>/dev/null || true
        done
    else
        echo "info:Running git fetch sequentially across repositories" >>"$output_file"
        for repo in "${repos[@]}"; do
            fetch_single_repo "$repo" "$output_file" "$failed_file"
        done
    fi

    echo "section:Updating local branches..." >>"$output_file"
    for repo in "${repos[@]}"; do
        if grep -Fqx "$repo" "$failed_file"; then
            continue
        fi
        update_single_repo "$repo" "$output_file"
    done
}

print_help() {
    echo "Usage: update-everything [options]"
    echo ""
    echo "Update all software and pull latest code."
    echo ""
    echo "Options:"
    echo "  -h, --help       Show this help message"
    echo "  -v, --verbose    Show verbose output"
    echo "  --dry-run        Show what would be done without executing"
    echo "  --sequential     Run repo git fetches sequentially (default is parallel fetches)"
    echo ""
    echo "Configuration:"
    echo "  Config file location: ~/.config/good-morning/config"
    echo ""
    echo "Tasks (run serially):"
    echo "  - Check for macOS updates"
    echo "  - brew update / upgrade / cleanup"
    echo "  - npm update -g"
    echo "  - Docker system prune"
    echo "  - Update Neovim plugins"
    echo "  - Pull latest main branch on all git repos in ~/code and ~/norm (only git fetch is parallelized)"
    exit 0
}

dry_run() {
    echo "Dry run - would execute the following:"
    echo ""
    echo "Configuration:"
    echo "  PARALLEL_GIT_FETCH=$PARALLEL"
    echo "  REPOS_DIRS=${REPOS_DIRS[*]}"
    echo "  RUN_BREW_UPDATE=$RUN_BREW_UPDATE"
    echo "  RUN_BREW_UPGRADE=$RUN_BREW_UPGRADE"
    echo "  RUN_BREW_CLEANUP=$RUN_BREW_CLEANUP"
    echo "  RUN_NPM_GLOBAL_UPDATE=$RUN_NPM_GLOBAL_UPDATE"
    echo "  PULL_REPOS=$PULL_REPOS"
    echo "  DOCKER_PRUNE=$DOCKER_PRUNE"
    echo "  CHECK_MACOS_UPDATES=$CHECK_MACOS_UPDATES"
    echo "  UPDATE_NVIM_PLUGINS=$UPDATE_NVIM_PLUGINS"
    echo ""

    if [ "$CHECK_MACOS_UPDATES" = true ]; then
        echo "Would check: macOS software updates"
    fi
    if [ "$RUN_BREW_UPDATE" = true ]; then
        echo "Would run: brew update"
    fi
    if [ "$RUN_BREW_UPGRADE" = true ]; then
        echo "Would run: brew upgrade"
    fi
    if [ "$RUN_BREW_CLEANUP" = true ]; then
        echo "Would run: brew cleanup"
    fi
    if [ "$RUN_NPM_GLOBAL_UPDATE" = true ]; then
        if command -v npm &>/dev/null; then
            echo "Would run: npm update -g"
        else
            echo "Would run: npm update -g (npm not installed)"
        fi
    fi
    if [ "$DOCKER_PRUNE" = true ]; then
        if command -v docker &>/dev/null; then
            echo "Would run: docker system prune -f"
        else
            echo "Would run: docker system prune -f (Docker not installed)"
        fi
    fi
    if [ "$UPDATE_NVIM_PLUGINS" = true ]; then
        if command -v nvim &>/dev/null; then
            echo "Would run: nvim --headless \"+Lazy! sync\" +qa"
        else
            echo "Would run: nvim plugin update (nvim not installed)"
        fi
    fi
    if [ "$PULL_REPOS" = true ]; then
        echo "Would pull latest (main or master) in:"
        for repos_dir in "${REPOS_DIRS[@]}"; do
            if [ -d "$repos_dir" ]; then
                echo "  $repos_dir:"
                for repo in "$repos_dir"/*/; do
                    if [ -d "$repo/.git" ]; then
                        echo "    - $(basename "$repo")"
                    fi
                done
            else
                echo "  $repos_dir (not found)"
            fi
        done
    fi
    exit 0
}

SHOW_HEADER=true
FORCE_SEQUENTIAL_FETCH=false

# Run all tasks sequentially (original behavior)
run_sequential() {
    check_macos_updates
    print_task_output "$TEMP_DIR/macos.out"

    print_info "Homebrew command log: $TEMP_DIR/brew.log"
    run_brew_tasks
    print_task_output "$TEMP_DIR/brew.out"

    print_info "npm global update log: $TEMP_DIR/npm-global.log"
    run_npm_global_update
    print_task_output "$TEMP_DIR/npm.out"

    run_docker_prune
    print_task_output "$TEMP_DIR/docker.out"

    update_nvim_plugins
    print_task_output "$TEMP_DIR/nvim.out"

    pull_repos
    if [ -f "$TEMP_DIR/repos.out" ] && [ -s "$TEMP_DIR/repos.out" ]; then
        print_section "Pulling latest in repos..."
        echo ""
        while IFS=: read -r type message; do
            case "$type" in
                success) print_success "$message" ;;
                error) print_error "$message" ;;
                info) print_info "$message" ;;
            esac
        done <"$TEMP_DIR/repos.out"
        echo ""
    fi
}

# Main
main() {
    local dry_run_mode=false

    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            -h | --help)
                print_help
                ;;
            -v | --verbose)
                VERBOSE=true
                shift
                ;;
            --no-header)
                SHOW_HEADER=false
                shift
                ;;
            --dry-run)
                dry_run_mode=true
                shift
                ;;
            --sequential)
                FORCE_SEQUENTIAL_FETCH=true
                shift
                ;;
            *)
                echo "Unknown option: $1"
                echo "Run 'update-everything --help' for usage."
                exit 1
                ;;
        esac
    done

    load_config
    if [ "$FORCE_SEQUENTIAL_FETCH" = true ]; then
        PARALLEL=false
    fi

    if [ "$dry_run_mode" = true ]; then
        dry_run
    fi

    setup_temp_dir

    if [ "$SHOW_HEADER" = true ]; then
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${BLUE}  Updating everything...${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
    fi

    run_sequential

    if [ "$SHOW_HEADER" = true ]; then
        echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${GREEN}  All updates complete!${NC}"
        echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    fi
}

main "$@"
